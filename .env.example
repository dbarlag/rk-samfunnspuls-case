# Supabase project credentials
# Get these from: Supabase Dashboard → Project Settings → API

# Public URL (safe to expose to client)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Anon key (read-only public access — safe for client)
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Service-role key (FULL ACCESS — server-side only, never expose to client)
# Used by ETL scripts in scripts/ to write to the database
SUPABASE_SERVICE_ROLE_KEY=eyJ...
